<?xml version="1.0" encoding="utf-8"?>

<launch>

  <arg name="device_name"       default="serial_device"/>
  <arg name="namespace"         default=""/>
  <arg name="port"              default="/dev/ttyUSB0"/>
  <arg name="baud_rate"         default="115200"/>

  <node pkg="roship_io" exec="serial_connection" name="$(var device_name)"  namespace="$(var namespace)">
    <param name="port" value="$(var port)"/>
    <param name="baud_rate" value="$(var baud_rate)"/>  
    <param from="$(find-pkg-share roship_io)/config/serial_connection.yaml"/>
  </node>

</launch>
